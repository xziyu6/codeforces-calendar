{
  "manifest_version": 3,
  "name": "Codeforces Calendar",
  "description": "Sync upcoming Codeforces contests to Google Calendar.",
  "version": "0.1.0",
  "permissions": ["identity", "storage"],
  "host_permissions": ["https://codeforces.com/*", "https://www.googleapis.com/calendar/v3/*"],
  "oauth2": {
    "client_id": "840627955632-vlnruj7po8srnj15j6kl6tddgoveas8g.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/calendar.events"]
  },
  "background": {
    "service_worker": "assets/serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://codeforces.com/contests*"],
      "js": ["assets/contentScript.js"],
      "css": ["src/styles/content.css"],
      "run_at": "document_idle"
    }
  ]
}
